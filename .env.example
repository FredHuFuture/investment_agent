# Optional: FRED API key for macro economic data (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Optional: Anthropic API key for LLM features (Phase 2)
# ANTHROPIC_API_KEY=your_key_here

# UI-07: Opt-in Bull/Bear synthesis via Anthropic.
# Defaults to false. When true AND ANTHROPIC_API_KEY is set, each analyze
# call adds ~$0.004 to run cost. ALWAYS short-circuited in backtest_mode
# (FOUND-04) so historical backtests never incur LLM costs.
ENABLE_LLM_SYNTHESIS=false
